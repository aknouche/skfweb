---
/**
 * Card Component
 * Reusable card for content blocks (news, events, etc.)
 * Simple and clean following SKF brand guidelines.
 */
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { class: className = '', padding = 'md' } = Astro.props;

const paddingStyles = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};
---

<div
  class:list={[
    'rounded-lg border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md',
    paddingStyles[padding],
    className,
  ]}
>
  <slot />
</div>
