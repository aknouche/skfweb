---
/**
 * Header Component
 * Main site header with logo and navigation.
 * Clean, professional design following SKF brand guidelines.
 */
import { NAVIGATION, BRAND } from '@lib/constants';
import Logo from '@components/ui/Logo.astro';

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-100 bg-white">
  <div class="container-wide">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline" aria-label={BRAND.name}>
        <Logo class="h-12 w-auto" />
        <div class="hidden sm:block">
          <span class="text-lg font-bold text-skf-blue">{BRAND.shortName}</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden items-center gap-8 lg:flex" aria-label="Huvudnavigering">
        {
          NAVIGATION.main.map((item) => (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium no-underline transition-colors',
                currentPath === item.href
                  ? 'text-skf-blue'
                  : 'text-gray-600 hover:text-skf-blue',
              ]}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="rounded-md p-2 text-gray-600 hover:bg-gray-100 hover:text-skf-blue lg:hidden"
        aria-label="Öppna meny"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div class="hidden border-t border-gray-100 lg:hidden" data-mobile-menu>
    <nav class="container-wide py-4" aria-label="Mobilnavigering">
      <ul class="space-y-2">
        {
          NAVIGATION.main.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block rounded-md px-4 py-2 text-base font-medium no-underline transition-colors',
                  currentPath === item.href
                    ? 'bg-skf-blue-50 text-skf-blue'
                    : 'text-gray-600 hover:bg-gray-50 hover:text-skf-blue',
                ]}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  // Simple mobile menu toggle
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');

  menuToggle?.addEventListener('click', () => {
    const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenu?.classList.toggle('hidden');
  });
</script>
