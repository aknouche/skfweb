# Sanity Configuration
# Copy this file to .env.local and fill in your values

# Get these from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Webhook secret for on-demand revalidation (keep this private)
REVALIDATION_SECRET=your-secret-here

# Resend email configuration
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@svenskakickboxning.se
RESEND_TO_EMAIL=info@svenskakickboxning.se
